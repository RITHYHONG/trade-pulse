# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (all workspace packages)
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage

# next.js (all apps)
**/.next/
**/out/

# Turborepo cache
.turbo/

# production
**/build
**/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
firebase-debug.log

# env files (can opt-in for committing if needed)
.env*

# firebase service account keys
*-firebase-adminsdk-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Firebase build / deployment output
.firebase/
.firebase/*

# functions build/output
functions/.next/
functions/node_modules/

