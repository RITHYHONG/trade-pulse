{
  "buildCommand": "pnpm build",
  "installCommand": "corepack enable && pnpm install --no-frozen-lockfile",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 20 * * *"
    }
  ]
}
